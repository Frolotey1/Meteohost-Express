## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio
.vs/
.vscode/
*.cache
*.cachefile
*.VC.db
*.VC.VC.opendb

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.VisualState.xml
TestResult.xml
coverage/
*.coverage
*.coveragexml

# NuGet Packages
*.nupkg
*.snupkg
packages/
*.nuget.props
*.nuget.targets

# Publish
/publish/
[Mm]igration[Bb]ackup/

# Secrets
appsettings.Development.json
appsettings.Production.json
appsettings.*.json
!appsettings.json
secrets.json
secrets.*.json
*.secrets.json
.env
.env.*
!.env.example

# User Secrets (ASP.NET Core)
secrets.json

# Docker
*.pidb
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml

# System files
*.tmp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Logs
*.log
logs/
log/

# Database
*.mdf
*.ldf
*.ndf
*.db
*.sqlite
*.sqlite3

# IDE
.idea/
*.iml
*.iws
*.ipr
project.lock.json
project.fragment.lock.json
artifacts/

# Node
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
package-lock.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
ENV/
env/

# Exceptions
!.gitkeep
!.vscode/extensions.json
